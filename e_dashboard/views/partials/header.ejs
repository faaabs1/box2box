<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Box2Box – <%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            pitch: { DEFAULT: '#0a2540', light: '#0d3060' },
            accent: '#f39c12',
          }
        }
      }
    }
  </script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    body { font-family:'Inter',sans-serif; background:#060f1e; color:#e2e8f0; }
    .card { background:#0d1f3c; border:1px solid rgba(255,255,255,0.07); border-radius:12px; }
    select,input { background:#0a1830; border:1px solid rgba(255,255,255,0.12); color:#e2e8f0; border-radius:8px; padding:6px 12px; font-size:0.875rem; }
    select:focus,input:focus { outline:2px solid #f39c12; outline-offset:2px; }
    tbody tr:hover td { background:rgba(255,255,255,0.03); }
    .my-row td { background:rgba(243,156,18,0.07); }
    .my-row:hover td { background:rgba(243,156,18,0.12); }
    .badge { display:inline-block; padding:2px 8px; border-radius:9999px; font-size:0.7rem; font-weight:600; }
    .badge-W { background:#16a34a22; color:#4ade80; border:1px solid #16a34a55; }
    .badge-D { background:#ca8a0422; color:#fbbf24; border:1px solid #ca8a0455; }
    .badge-L { background:#dc262622; color:#f87171; border:1px solid #dc262655; }
  </style>
</head>
<body class="min-h-screen">
<nav class="sticky top-0 z-50 border-b border-white/10" style="background:#060f1e;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-14">
    <div class="flex items-center gap-2">
      <span class="text-xl">⚽</span>
      <span class="font-bold text-white text-lg tracking-tight">Box2Box</span>
    </div>
    <div class="flex items-center gap-1">
      <a href="/" class="px-4 py-2 rounded-lg text-sm font-medium transition-colors <%= page==='league'?'bg-amber-500 text-slate-900':'text-slate-300 hover:bg-white/8' %>">League</a>
      <a href="/team?team_id=<%= myTeamId %>" class="px-4 py-2 rounded-lg text-sm font-medium transition-colors <%= page==='team'?'bg-amber-500 text-slate-900':'text-slate-300 hover:bg-white/8' %>">My Team</a>
      <a href="/players" class="px-4 py-2 rounded-lg text-sm font-medium transition-colors <%= page==='players'?'bg-amber-500 text-slate-900':'text-slate-300 hover:bg-white/8' %>">Players</a>
    </div>
  </div>
</nav>
<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
