<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Box2Box – <%- typeof title !== 'undefined' ? title : 'Dashboard' %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            pitch: { DEFAULT: '#0a2540', light: '#0d3060', card: '#112244' },
            grass: { DEFAULT: '#2ecc71', dark: '#27ae60' },
            accent: '#f39c12',
          }
        }
      }
    }
  </script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'Inter', sans-serif; background-color: #060f1e; color: #e2e8f0; }
    .nav-link { @apply px-4 py-2 rounded-lg text-sm font-medium transition-colors; }
    .nav-link:hover { background-color: rgba(255,255,255,0.08); }
    .nav-link.active { background-color: #f39c12; color: #060f1e; }
    .card { background: #0d1f3c; border: 1px solid rgba(255,255,255,0.07); border-radius: 12px; }
    .stat-card { @apply card p-5 flex flex-col gap-1; }
    .badge-W { background:#16a34a22; color:#4ade80; border:1px solid #16a34a44; }
    .badge-D { background:#ca8a0422; color:#fbbf24; border:1px solid #ca8a0444; }
    .badge-L { background:#dc262622; color:#f87171; border:1px solid #dc262644; }
    select, input { background:#0a1830; border:1px solid rgba(255,255,255,0.12); color:#e2e8f0; border-radius:8px; padding:6px 12px; font-size:0.875rem; }
    select:focus, input:focus { outline:2px solid #f39c12; outline-offset:2px; }
    table { border-collapse: separate; border-spacing: 0; }
    thead th { background:#060f1e; }
    tbody tr:hover td { background: rgba(255,255,255,0.03); }
    .my-team-row td { background: rgba(243,156,18,0.06); }
    .my-team-row:hover td { background: rgba(243,156,18,0.10); }
  </style>
</head>
<body class="min-h-screen">

  <!-- Navbar -->
  <nav class="sticky top-0 z-50 border-b border-white/10" style="background:#060f1e;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-14">
      <div class="flex items-center gap-3">
        <span class="text-xl">⚽</span>
        <span class="font-bold text-white tracking-tight text-lg">Box2Box</span>
      </div>
      <div class="flex items-center gap-1">
        <a href="/" class="nav-link <%= page === 'league' ? 'active' : 'text-slate-300' %>">League</a>
        <a href="/team" class="nav-link <%= page === 'team' ? 'active' : 'text-slate-300' %>">My Team</a>
        <a href="/players" class="nav-link <%= page === 'players' ? 'active' : 'text-slate-300' %>">Players</a>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <%- body %>
  </main>

  <footer class="text-center text-xs text-slate-600 py-8">Box2Box Analytics © 2026</footer>
</body>
</html>
