<%- include('partials/header', { title: (selectedTeam ? selectedTeam.team_name : 'Team') + ' – Stats', page, myTeamId }) %>

<!-- Filters -->
<div class="flex flex-wrap items-end gap-3 mb-8">
  <div>
    <label class="block text-xs text-slate-400 mb-1 font-medium">Team</label>
    <select id="teamSelect" onchange="applyFilters()">
      <% allTeams.forEach(t => { %>
        <option value="<%= t.team_id %>" <%= String(t.team_id) === String(selectedTeamId) ? 'selected' : '' %>><%= t.team_name %></option>
      <% }) %>
    </select>
  </div>
  <div>
    <label class="block text-xs text-slate-400 mb-1 font-medium">Season</label>
    <select id="seasonSelect" onchange="applyFilters()">
      <% seasons.forEach(s => { %>
        <option value="<%= s.season_id %>" <%= String(s.season_id) === String(selectedSeason) ? 'selected' : '' %>><%= s.season_name %></option>
      <% }) %>
    </select>
  </div>
  <div>
    <label class="block text-xs text-slate-400 mb-1 font-medium">League</label>
    <select id="leagueSelect" onchange="applyFilters()">
      <option value="">All Leagues</option>
      <% leagues.forEach(l => { %>
        <option value="<%= l.league_id %>" <%= String(l.league_id) === String(selectedLeague) ? 'selected' : '' %>><%= l.league_name %></option>
      <% }) %>
    </select>
  </div>
</div>

<!-- Team Header -->
<div class="flex items-center gap-4 mb-6">
  <div class="w-14 h-14 rounded-full bg-amber-500/20 border border-amber-500/40 flex items-center justify-center text-2xl">🏟️</div>
  <div>
    <h1 class="text-2xl font-bold text-white"><%= selectedTeam ? selectedTeam.team_name : `Team ${selectedTeamId}` %></h1>
    <p class="text-slate-400 text-sm"><%= seasons.find(s => String(s.season_id) === String(selectedSeason))?.season_name || '' %></p>
  </div>
</div>

<!-- Season Stats Cards -->
<%
  const gp     = gamesPlayed || 1;
  const avgPts = stats.points / gp;
  const avgGF  = stats.goals_scored / gp;
  const avgGA  = stats.goals_conceded / gp;
  const fmt2   = n => Number(n).toFixed(2);
  const dSign  = n => (n >= 0 ? '+' : '') + Number(n).toFixed(2);
  const lAvgs  = leagueAvgs || {};
  const wins   = games.filter(g => g.result === 'W').length;
  const draws  = games.filter(g => g.result === 'D').length;
  const losses = games.filter(g => g.result === 'L').length;
%>
<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
  <div class="card p-5">
    <p class="text-xs text-slate-400 font-medium mb-1">Points</p>
    <p class="text-3xl font-bold text-amber-400"><%= stats.points %></p>
    <p class="text-sm text-slate-300 mt-1"><%= fmt2(avgPts) %><span class="text-slate-500 text-xs ml-1">/game</span></p>
    <% if (lAvgs.avg_pts != null) { const d = avgPts - lAvgs.avg_pts; %>
      <p class="text-xs font-medium mt-0.5 <%= d >= 0 ? 'text-green-400' : 'text-red-400' %>"><%= dSign(d) %> vs league avg</p>
    <% } %>
  </div>
  <div class="card p-5">
    <p class="text-xs text-slate-400 font-medium mb-1">Goals Scored</p>
    <p class="text-3xl font-bold text-green-400"><%= stats.goals_scored %></p>
    <p class="text-sm text-slate-300 mt-1"><%= fmt2(avgGF) %><span class="text-slate-500 text-xs ml-1">/game</span></p>
    <% if (lAvgs.avg_gf != null) { const d = avgGF - lAvgs.avg_gf; %>
      <p class="text-xs font-medium mt-0.5 <%= d >= 0 ? 'text-green-400' : 'text-red-400' %>"><%= dSign(d) %> vs league avg</p>
    <% } %>
  </div>
  <div class="card p-5">
    <p class="text-xs text-slate-400 font-medium mb-1">Goals Conceded</p>
    <p class="text-3xl font-bold text-red-400"><%= stats.goals_conceded %></p>
    <p class="text-sm text-slate-300 mt-1"><%= fmt2(avgGA) %><span class="text-slate-500 text-xs ml-1">/game</span></p>
    <% if (lAvgs.avg_ga != null) { const d = avgGA - lAvgs.avg_ga; %>
      <p class="text-xs font-medium mt-0.5 <%= d <= 0 ? 'text-green-400' : 'text-red-400' %>"><%= dSign(d) %> vs league avg</p>
    <% } %>
  </div>
  <div class="card p-5">
    <p class="text-xs text-slate-400 font-medium mb-1">W / D / L</p>
    <p class="text-3xl font-bold text-white"><%= wins %><span class="text-slate-500 mx-1 text-xl">/</span><%= draws %><span class="text-slate-500 mx-1 text-xl">/</span><%= losses %></p>
    <p class="text-sm text-slate-400 mt-1"><%= gamesPlayed %> games played</p>
  </div>
</div>

<div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

  <!-- Match Results -->
  <div class="xl:col-span-2">
    <h2 class="text-lg font-semibold text-white mb-3">Match Results</h2>
    <div class="card overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-xs text-slate-400 uppercase tracking-wider">
              <th class="px-4 py-3 text-left">Date</th>
              <th class="px-4 py-3 text-left">Round</th>
              <th class="px-4 py-3 text-left">Opponent</th>
              <th class="px-4 py-3 text-center">Venue</th>
              <th class="px-4 py-3 text-center">Score</th>
              <th class="px-4 py-3 text-center">Result</th>
            </tr>
          </thead>
          <tbody>
            <% games.forEach(g => { %>
              <tr class="border-t border-white/5">
                <td class="px-4 py-3 text-slate-400 text-xs"><%= g.game_date ? new Date(g.game_date).toLocaleDateString('de-DE') : '–' %></td>
                <td class="px-4 py-3 text-slate-400"><%= g.game_round || '–' %></td>
                <td class="px-4 py-3 font-medium text-white"><%= g.opponent_name %></td>
                <td class="px-4 py-3 text-center">
                  <span class="badge <%= g.game_location === 'home' ? 'text-blue-300 bg-blue-500/15 border border-blue-500/30' : 'text-slate-300 bg-white/5 border border-white/10' %>">
                    <%= g.game_location === 'home' ? 'H' : 'A' %>
                  </span>
                </td>
                <td class="px-4 py-3 text-center font-mono text-white"><%= g.goals_scored %>–<%= g.goals_conceded %></td>
                <td class="px-4 py-3 text-center">
                  <span class="badge badge-<%= g.result %>"><%= g.result %></span>
                </td>
              </tr>
            <% }) %>
            <% if (!games.length) { %>
              <tr><td colspan="6" class="text-center text-slate-500 py-10">No matches found</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Form Chart -->
  <div class="flex flex-col gap-6">
    <div>
      <h2 class="text-lg font-semibold text-white mb-3">Goals per Game</h2>
      <div class="card p-4">
        <canvas id="formChart" height="220"></canvas>
      </div>
    </div>
    <div>
      <h2 class="text-lg font-semibold text-white mb-3">Points per Game</h2>
      <div class="card p-4">
        <canvas id="pointsChart" height="220"></canvas>
      </div>
    </div>
  </div>

</div>

<!-- Goals Timing Chart -->
<% if (timing && timing.length) { %>
<div class="mt-6 mb-8">
  <h2 class="text-lg font-semibold text-white mb-3">When Goals Were Scored &amp; Conceded</h2>
  <div class="card p-4">
    <canvas id="timingChart" height="80"></canvas>
  </div>
</div>
<% } %>

<script>
  const games = <%- JSON.stringify(games) %>;
  const timing = <%- JSON.stringify(timing || []) %>;

  function applyFilters() {
    const team = document.getElementById('teamSelect').value;
    const season = document.getElementById('seasonSelect').value;
    const league = document.getElementById('leagueSelect').value;
    let url = `/team?team_id=${team}&season_id=${season}`;
    if (league) url += `&league_id=${league}`;
    window.location.href = url;
  }

  const chronoGames = [...games].reverse();
  const gameLabels = chronoGames.map((g, i) => `R${g.game_round || i+1}`);

  new Chart(document.getElementById('formChart'), {
    type: 'line',
    data: {
      labels: gameLabels,
      datasets: [
        {
          label: 'Scored',
          data: chronoGames.map(g => g.goals_scored),
          borderColor: '#4ade80',
          backgroundColor: 'rgba(74,222,128,0.1)',
          tension: 0.3,
          fill: true,
          pointRadius: 3,
        },
        {
          label: 'Conceded',
          data: chronoGames.map(g => g.goals_conceded),
          borderColor: '#f87171',
          backgroundColor: 'rgba(248,113,113,0.1)',
          tension: 0.3,
          fill: true,
          pointRadius: 3,
        }
      ]
    },
    options: {
      responsive: true,
      plugins: { legend: { labels: { color: '#94a3b8', font: { size: 11 } } } },
      scales: {
        x: { ticks: { color: '#64748b', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' } },
        y: { ticks: { color: '#64748b', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' }, beginAtZero: true }
      }
    }
  });

  // Goals timing chart
  if (timing.length) {
    new Chart(document.getElementById('timingChart'), {
      type: 'bar',
      data: {
        labels: timing.map(b => b.bucket),
        datasets: [
          {
            label: 'Scored',
            data: timing.map(b => b.scored),
            backgroundColor: 'rgba(74,222,128,0.75)',
            borderColor: '#4ade80',
            borderWidth: 1,
            borderRadius: 3,
          },
          {
            label: 'Conceded',
            data: timing.map(b => b.conceded),
            backgroundColor: 'rgba(248,113,113,0.75)',
            borderColor: '#f87171',
            borderWidth: 1,
            borderRadius: 3,
          }
        ]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { labels: { color: '#94a3b8', font: { size: 11 } } },
          tooltip: { callbacks: { title: items => `Minute ${items[0].label}` } }
        },
        scales: {
          x: { ticks: { color: '#64748b', font: { size: 11 } }, grid: { color: 'rgba(255,255,255,0.04)' } },
          y: { ticks: { color: '#64748b', font: { size: 11 }, stepSize: 1 }, grid: { color: 'rgba(255,255,255,0.04)' }, beginAtZero: true }
        }
      }
    });
  }

  // Cumulative points
  let cumPts = 0;
  const cumPoints = chronoGames.map(g => { cumPts += g.points; return cumPts; });

  new Chart(document.getElementById('pointsChart'), {
    type: 'line',
    data: {
      labels: gameLabels,
      datasets: [{
        label: 'Cumulative Points',
        data: cumPoints,
        borderColor: '#f39c12',
        backgroundColor: 'rgba(243,156,18,0.1)',
        tension: 0.3,
        fill: true,
        pointRadius: 3,
      }]
    },
    options: {
      responsive: true,
      plugins: { legend: { display: false } },
      scales: {
        x: { ticks: { color: '#64748b', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' } },
        y: { ticks: { color: '#64748b', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' }, beginAtZero: true }
      }
    }
  });
</script>

<%- include('partials/footer') %>
