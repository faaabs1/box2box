<%- include('partials/header', { title: (selectedTeam ? selectedTeam.team_name : 'Team') + ' – Stats', page, myTeamId }) %>

<!-- Filters -->
<div class="flex flex-wrap items-end gap-3 mb-8">
  <div>
    <label class="block text-xs text-slate-400 mb-1 font-medium">Season</label>
    <select id="seasonSelect" onchange="applyFilters()">
      <% seasons.forEach(s => { %>
        <option value="<%= s.season_id %>" <%= String(s.season_id) === String(selectedSeason) ? 'selected' : '' %>><%= s.season_name %></option>
      <% }) %>
    </select>
  </div>
  <div>
    <label class="block text-xs text-slate-400 mb-1 font-medium">League</label>
    <select id="leagueSelect" onchange="applyFilters()">
      <option value="">All Leagues</option>
      <% leagues.forEach(l => { %>
        <option value="<%= l.league_id %>" <%= String(l.league_id) === String(selectedLeague) ? 'selected' : '' %>><%= l.league_name %></option>
      <% }) %>
    </select>
  </div>
  <div>
    <label class="block text-xs text-slate-400 mb-1 font-medium">Club</label>
    <select id="teamSelect" onchange="applyFilters()">
      <% allTeams.forEach(t => { %>
        <option value="<%= t.team_id %>" <%= String(t.team_id) === String(selectedTeamId) ? 'selected' : '' %>><%= t.team_name %></option>
      <% }) %>
    </select>
  </div>
  <div>
    <label class="block text-xs text-slate-400 mb-1 font-medium">Venue</label>
    <select id="locationSelect" onchange="applyFilters()">
      <option value="" <%= !selectedLocation ? 'selected' : '' %>>All</option>
      <option value="home" <%= selectedLocation === 'home' ? 'selected' : '' %>>Home</option>
      <option value="away" <%= selectedLocation === 'away' ? 'selected' : '' %>>Away</option>
    </select>
  </div>
</div>

<!-- Team Header -->
<div class="flex items-center gap-4 mb-6">
  <div class="w-14 h-14 rounded-full bg-amber-500/20 border border-amber-500/40 flex items-center justify-center text-2xl">🏟️</div>
  <div>
    <h1 class="text-2xl font-bold text-white"><%= selectedTeam ? selectedTeam.team_name : `Team ${selectedTeamId}` %></h1>
    <p class="text-slate-400 text-sm"><%= seasons.find(s => String(s.season_id) === String(selectedSeason))?.season_name || '' %></p>
  </div>
</div>

<!-- Season Stats Cards -->
<%
  const gp     = gamesPlayed || 1;
  const gpH    = games.filter(g => g.game_location === 'home').length || 1;
  const gpA    = games.filter(g => g.game_location === 'away').length || 1;
  const avgPts = stats.points / gp;
  const avgGF  = stats.goals_scored / gp;
  const avgGA  = stats.goals_conceded / gp;
  const fmt2   = n => Number(n).toFixed(2);
  const dSign  = n => (n >= 0 ? '+' : '') + Number(n).toFixed(2);
  const lAvgs  = leagueAvgs || {};
  const wins   = games.filter(g => g.result === 'W').length;
  const draws  = games.filter(g => g.result === 'D').length;
  const losses = games.filter(g => g.result === 'L').length;
%>
<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">

  <!-- Points -->
  <div class="card p-5">
    <p class="text-xs text-slate-400 font-medium mb-2">Points</p>
    <p class="text-3xl font-bold text-amber-400"><%= stats.points %></p>
    <p class="text-sm text-slate-300 mt-1"><%= fmt2(avgPts) %><span class="text-slate-500 text-xs ml-1">/game</span></p>
    <% if (lAvgs.avg_pts != null) { const d = avgPts - lAvgs.avg_pts; %>
      <p class="text-xs font-medium mt-0.5 <%= d >= 0 ? 'text-green-400' : 'text-red-400' %>"><%= dSign(d) %> vs lg</p>
    <% } %>
    <div class="mt-3 pt-2 border-t border-white/5 grid grid-cols-2 gap-x-2 text-xs">
      <div><span class="text-slate-500">Home</span><br><span class="text-white font-semibold"><%= stats.home?.points ?? '-' %></span><span class="text-slate-500 ml-1"><%= fmt2((stats.home?.points||0)/gpH) %>/g</span></div>
      <div><span class="text-slate-500">Away</span><br><span class="text-white font-semibold"><%= stats.away?.points ?? '-' %></span><span class="text-slate-500 ml-1"><%= fmt2((stats.away?.points||0)/gpA) %>/g</span></div>
    </div>
  </div>

  <!-- Goal Difference + W/D/L -->
  <div class="card p-5">
    <p class="text-xs text-slate-400 font-medium mb-2">Goal Difference</p>
    <% const gd = stats.goal_difference; %>
    <p class="text-3xl font-bold <%= gd > 0 ? 'text-green-400' : gd < 0 ? 'text-red-400' : 'text-slate-400' %>"><%= gd >= 0 ? '+' : '' %><%= gd %></p>
    <p class="text-sm text-slate-300 mt-1"><%= dSign(gd/gp) %><span class="text-slate-500 text-xs ml-1">/game</span></p>
    <div class="mt-3 pt-2 border-t border-white/5 grid grid-cols-2 gap-x-2 text-xs">
      <% const gdH = stats.home?.goal_difference ?? 0; const gdA = stats.away?.goal_difference ?? 0; %>
      <div><span class="text-slate-500">Home</span><br><span class="font-semibold <%= gdH >= 0 ? 'text-green-300' : 'text-red-300' %>"><%= gdH >= 0 ? '+' : '' %><%= gdH %></span><span class="text-slate-500 ml-1"><%= dSign(gdH/gpH) %>/g</span></div>
      <div><span class="text-slate-500">Away</span><br><span class="font-semibold <%= gdA >= 0 ? 'text-green-300' : 'text-red-300' %>"><%= gdA >= 0 ? '+' : '' %><%= gdA %></span><span class="text-slate-500 ml-1"><%= dSign(gdA/gpA) %>/g</span></div>
    </div>
    <p class="text-xs text-slate-500 mt-2"><%= wins %>W · <%= draws %>D · <%= losses %>L</p>
  </div>

  <!-- Goals Scored -->
  <div class="card p-5">
    <p class="text-xs text-slate-400 font-medium mb-2">Goals Scored</p>
    <p class="text-3xl font-bold text-green-400"><%= stats.goals_scored %></p>
    <p class="text-sm text-slate-300 mt-1"><%= fmt2(avgGF) %><span class="text-slate-500 text-xs ml-1">/game</span></p>
    <% if (lAvgs.avg_gf != null) { const d = avgGF - lAvgs.avg_gf; %>
      <p class="text-xs font-medium mt-0.5 <%= d >= 0 ? 'text-green-400' : 'text-red-400' %>"><%= dSign(d) %> vs lg</p>
    <% } %>
    <div class="mt-3 pt-2 border-t border-white/5 grid grid-cols-2 gap-x-2 text-xs">
      <div><span class="text-slate-500">Home</span><br><span class="text-green-300 font-semibold"><%= stats.home?.goals_scored ?? '-' %></span><span class="text-slate-500 ml-1"><%= fmt2((stats.home?.goals_scored||0)/gpH) %>/g</span></div>
      <div><span class="text-slate-500">Away</span><br><span class="text-green-300 font-semibold"><%= stats.away?.goals_scored ?? '-' %></span><span class="text-slate-500 ml-1"><%= fmt2((stats.away?.goals_scored||0)/gpA) %>/g</span></div>
    </div>
  </div>

  <!-- Goals Conceded -->
  <div class="card p-5">
    <p class="text-xs text-slate-400 font-medium mb-2">Goals Conceded</p>
    <p class="text-3xl font-bold text-red-400"><%= stats.goals_conceded %></p>
    <p class="text-sm text-slate-300 mt-1"><%= fmt2(avgGA) %><span class="text-slate-500 text-xs ml-1">/game</span></p>
    <% if (lAvgs.avg_ga != null) { const d = avgGA - lAvgs.avg_ga; %>
      <p class="text-xs font-medium mt-0.5 <%= d <= 0 ? 'text-green-400' : 'text-red-400' %>"><%= dSign(d) %> vs lg</p>
    <% } %>
    <div class="mt-3 pt-2 border-t border-white/5 grid grid-cols-2 gap-x-2 text-xs">
      <div><span class="text-slate-500">Home</span><br><span class="text-red-300 font-semibold"><%= stats.home?.goals_conceded ?? '-' %></span><span class="text-slate-500 ml-1"><%= fmt2((stats.home?.goals_conceded||0)/gpH) %>/g</span></div>
      <div><span class="text-slate-500">Away</span><br><span class="text-red-300 font-semibold"><%= stats.away?.goals_conceded ?? '-' %></span><span class="text-slate-500 ml-1"><%= fmt2((stats.away?.goals_conceded||0)/gpA) %>/g</span></div>
    </div>
  </div>

</div>

<% if (!selectedLocation && leagueAvgs) { %>
<!-- Strength over Time -->
<div class="mb-8">
  <h2 class="text-lg font-semibold text-white mb-3">Strength over Time <span class="text-xs font-normal text-slate-400 ml-1">rolling naive (lines) &middot; DC season estimate (dashed) &middot; 1.0 = average</span></h2>
  <div class="card p-4">
    <canvas id="strengthChart" height="120"></canvas>
  </div>
</div>
<% } %>

<!-- Top Scorers -->
<% if (teamScorers && teamScorers.length) { %>
<div class="mb-6">
  <h2 class="text-lg font-semibold text-white mb-3">Top Scorers</h2>
  <div class="grid grid-cols-3 gap-4">
    <% teamScorers.forEach((s, i) => { %>
    <div class="card p-4 flex items-center gap-3">
      <span class="text-2xl font-bold text-slate-500">#<%= i + 1 %></span>
      <div class="flex-1 min-w-0">
        <p class="font-semibold text-white text-sm truncate"><%= s.player_name %></p>
        <p class="text-xs text-slate-400 mt-0.5"><%= s.apps %> apps &middot; G/90: <span class="text-amber-300"><%= s.g90 %></span> &middot; Adj: <span class="text-sky-300"><%= s.adj_goals %></span></p>
      </div>
      <p class="text-3xl font-bold text-amber-400 shrink-0"><%= s.goals %></p>
    </div>
    <% }) %>
  </div>
</div>
<% } %>

<!-- Match Results (full width) -->
<div class="mb-6">
  <h2 class="text-lg font-semibold text-white mb-3">Match Results</h2>
  <div class="card overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-xs text-slate-400 uppercase tracking-wider">
            <th class="px-4 py-3 text-left">Date</th>
            <th class="px-4 py-3 text-left">Round</th>
            <th class="px-4 py-3 text-left">Opponent</th>
            <th class="px-4 py-3 text-center">Venue</th>
            <th class="px-4 py-3 text-center">Score</th>
            <th class="px-4 py-3 text-center">Result</th>
          </tr>
        </thead>
        <tbody>
          <% games.forEach(g => { %>
            <tr class="border-t border-white/5">
              <td class="px-4 py-3 text-slate-400 text-xs"><%= g.game_date ? new Date(g.game_date).toLocaleDateString('de-DE') : '–' %></td>
              <td class="px-4 py-3 text-slate-400"><%= g.game_round || '–' %></td>
              <td class="px-4 py-3 font-medium text-white"><%= g.opponent_name %></td>
              <td class="px-4 py-3 text-center">
                <span class="badge <%= g.game_location === 'home' ? 'text-blue-300 bg-blue-500/15 border border-blue-500/30' : 'text-slate-300 bg-white/5 border border-white/10' %>">
                  <%= g.game_location === 'home' ? 'H' : 'A' %>
                </span>
              </td>
              <td class="px-4 py-3 text-center font-mono text-white"><%= g.goals_scored %>–<%= g.goals_conceded %></td>
              <td class="px-4 py-3 text-center">
                <span class="badge badge-<%= g.result %>"><%= g.result %></span>
              </td>
            </tr>
          <% }) %>
          <% if (!games.length) { %>
            <tr><td colspan="6" class="text-center text-slate-500 py-10">No matches found</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Chart window control -->
<div class="flex items-center justify-end gap-2 mb-4">
  <span class="text-xs text-slate-500">Window:</span>
  <select id="nSelect" onchange="renderTimeCharts()" class="text-xs bg-slate-800 border border-white/10 text-slate-300 rounded px-2 py-1">
    <option value="5">Last 5 games</option>
    <option value="10">Last 10 games</option>
    <option value="all" selected>All games</option>
  </select>
</div>
<!-- Charts 2×2 grid -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-6">

  <!-- Goal Difference -->
  <div>
    <h2 class="text-lg font-semibold text-white mb-3">Goal Difference</h2>
    <div class="card p-4">
      <canvas id="gdChart" height="220"></canvas>
    </div>
  </div>

  <!-- Avg Points per Game (running season average) -->
  <div>
    <h2 class="text-lg font-semibold text-white mb-3">Avg Points / Game</h2>
    <div class="card p-4">
      <canvas id="pointsAvgChart" height="220"></canvas>
    </div>
  </div>

  <!-- Cumulative Goals Scored vs Conceded -->
  <div>
    <h2 class="text-lg font-semibold text-white mb-3">Cumulative Goals</h2>
    <div class="card p-4">
      <canvas id="cumGoalsChart" height="220"></canvas>
    </div>
  </div>

  <!-- Cumulative Goal Difference -->
  <div>
    <h2 class="text-lg font-semibold text-white mb-3">Cumulative Goal Difference</h2>
    <div class="card p-4">
      <canvas id="cumGdChart" height="220"></canvas>
    </div>
  </div>

  <!-- Goals Timing -->
  <% if (timing && timing.length) { %>
  <div>
    <h2 class="text-lg font-semibold text-white mb-3">When Goals Were Scored &amp; Conceded</h2>
    <div class="card p-4">
      <canvas id="timingChart" height="220"></canvas>
    </div>
  </div>
  <% } %>

  <!-- Player Minutes -->
  <% if (playerMinutes && playerMinutes.length) { %>
  <div class="md:col-span-2">
    <h2 class="text-lg font-semibold text-white mb-3">Player Minutes</h2>
    <div class="card p-4">
      <canvas id="minutesChart"></canvas>
    </div>
  </div>
  <% } %>

  <!-- Goals by Type -->
  <% if (goalsByType && goalsByType.length) { %>
  <div>
    <h2 class="text-lg font-semibold text-white mb-3">Goals Scored by Type</h2>
    <div class="card p-4">
      <canvas id="goalTypeScoredChart" height="180"></canvas>
    </div>
  </div>
  <div>
    <h2 class="text-lg font-semibold text-white mb-3">Goals Conceded by Type</h2>
    <div class="card p-4">
      <canvas id="goalTypeConcededChart" height="180"></canvas>
    </div>
  </div>
  <% } %>

</div>

<script>
  const games = <%- JSON.stringify(games) %>;
  const timing = <%- JSON.stringify(timing || []) %>;
  const leagueAvgs   = <%- JSON.stringify(leagueAvgs   || null) %>;
  const teamStrength = <%- JSON.stringify(teamStrength || null) %>;
  const playerMinutes = <%- JSON.stringify(playerMinutes || []) %>;
  const goalsByType = <%- JSON.stringify(goalsByType || []) %>;

  function applyFilters() {
    const team = document.getElementById('teamSelect').value;
    const season = document.getElementById('seasonSelect').value;
    const league = document.getElementById('leagueSelect').value;
    const location = document.getElementById('locationSelect').value;
    let url = `/team?team_id=${team}&season_id=${season}`;
    if (league) url += `&league_id=${league}`;
    if (location) url += `&location=${location}`;
    window.location.href = url;
  }

  const chronoGames = [...games].reverse();
  const gameLabels = chronoGames.map((g, i) => `R${g.game_round || i + 1}`);

  function getWindowSlice() {
    const nVal = document.getElementById('nSelect').value;
    return nVal === 'all' ? chronoGames : chronoGames.slice(-parseInt(nVal));
  }
  function sliceLabels(slice) {
    const offset = chronoGames.length - slice.length;
    return slice.map((g, i) => `R${g.game_round || offset + i + 1}`);
  }

  // --- Chart 1: Goal Difference ---
  let gdChart;
  let gdSlice = [];
  function renderGdChart(slice) {
    gdSlice = slice || getWindowSlice();
    const labels = sliceLabels(gdSlice);
    const rawGd = gdSlice.map(g => g.goal_difference != null ? g.goal_difference : (g.goals_scored - g.goals_conceded));
    // Wins/losses as bars; draws get null (invisible)
    const gdData = rawGd.map(v => v === 0 ? null : v);
    // Draws as a thin centred bar (base –0.15 → value 0.15 = horizontal line at 0)
    const drawData = rawGd.map(v => v === 0 ? 0.15 : null);
    const bgColors = rawGd.map(v => v > 0 ? 'rgba(74,222,128,0.75)' : v < 0 ? 'rgba(248,113,113,0.75)' : 'transparent');
    const bdColors = rawGd.map(v => v > 0 ? '#4ade80' : v < 0 ? '#f87171' : 'transparent');
    const tooltipCallbacks = {
      title(items) {
        if (!items.length) return '';
        const g = gdSlice[items[0].dataIndex];
        if (!g) return '';
        const loc = g.game_location === 'home' ? 'vs' : '@';
        return `${loc} ${g.opponent_name || 'Unknown'}`;
      },
      label(item) {
        const g = gdSlice[item.dataIndex];
        if (!g) return null;
        const score = `${g.goals_scored}\u2013${g.goals_conceded}`;
        const date = g.game_date ? new Date(g.game_date).toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' }) : '';
        return [`${g.result}  ${score}`, date];
      }
    };
    if (gdChart) gdChart.destroy();
    gdChart = new Chart(document.getElementById('gdChart'), {
      type: 'bar',
      data: {
        labels,
        datasets: [
          { label: 'Goal Diff', data: gdData, backgroundColor: bgColors, borderColor: bdColors, borderWidth: 1, borderRadius: 4 },
          { label: '_draw', data: drawData, base: -0.15, backgroundColor: 'rgba(148,163,184,0.9)', borderColor: '#94a3b8', borderWidth: 0, borderRadius: 1 },
        ]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: tooltipCallbacks
          }
        },
        scales: {
          x: { ticks: { color: '#64748b', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' } },
          y: { ticks: { color: '#64748b', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' } }
        },
        datasets: { bar: { barPercentage: 1.0, categoryPercentage: 0.95 } }
      }
    });
  }

  // --- Chart 2: Running average points per game ---
  let avgPtsChartInst;
  function renderAvgPtsChart(slice) {
    slice = slice || getWindowSlice();
    const labels = sliceLabels(slice);
    let cumPts = 0;
    const avgPtsArr = slice.map((g, i) => {
      cumPts += g.points;
      return +(cumPts / (i + 1)).toFixed(2);
    });
    const lgAvgPts = leagueAvgs ? +leagueAvgs.avg_pts.toFixed(2) : null;
    const lgFlatPts = lgAvgPts !== null ? labels.map(() => lgAvgPts) : [];
    if (avgPtsChartInst) avgPtsChartInst.destroy();
    avgPtsChartInst = new Chart(document.getElementById('pointsAvgChart'), {
      type: 'line',
      data: {
        labels,
        datasets: [
          {
            label: 'Avg Pts/Game',
            data: avgPtsArr,
            borderColor: '#f39c12',
            backgroundColor: 'rgba(243,156,18,0.1)',
            tension: 0.3,
            fill: true,
            pointRadius: 3,
          },
          ...(lgAvgPts !== null ? [{
            label: 'League Avg',
            data: lgFlatPts,
            borderColor: '#94a3b8',
            borderDash: [5, 4],
            backgroundColor: 'transparent',
            tension: 0,
            fill: false,
            pointRadius: 0,
            borderWidth: 1.5,
          }] : []),
        ]
      },
      options: {
        responsive: true,
        plugins: { legend: { labels: { color: '#94a3b8', font: { size: 11 }, filter: i => i.text !== 'League Avg' || lgAvgPts !== null } } },
        scales: {
          x: { ticks: { color: '#64748b', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' } },
          y: { ticks: { color: '#64748b', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' }, beginAtZero: true }
        }
      }
    });
  }

  // --- Chart 3: Cumulative goals scored vs conceded ---
  let cumGoalsChartInst;
  function renderCumGoalsChart(slice) {
    slice = slice || getWindowSlice();
    const labels = sliceLabels(slice);
    let cGF = 0, cGA = 0;
    const cumGFArr = slice.map(g => { cGF += g.goals_scored; return cGF; });
    const cumGAArr = slice.map(g => { cGA += g.goals_conceded; return cGA; });
    const lgAvgScoredArr = leagueAvgs ? labels.map((_, i) => +((i + 1) * leagueAvgs.avg_gf).toFixed(1)) : [];
    const lgAvgConcededArr = leagueAvgs ? labels.map((_, i) => +((i + 1) * leagueAvgs.avg_ga).toFixed(1)) : [];
    if (cumGoalsChartInst) cumGoalsChartInst.destroy();
    cumGoalsChartInst = new Chart(document.getElementById('cumGoalsChart'), {
      type: 'line',
      data: {
        labels,
        datasets: [
          { label: 'Goals Scored', data: cumGFArr, borderColor: '#4ade80', backgroundColor: 'rgba(74,222,128,0.08)', tension: 0.2, fill: false, pointRadius: 3 },
          { label: 'Goals Conceded', data: cumGAArr, borderColor: '#f87171', backgroundColor: 'rgba(248,113,113,0.08)', tension: 0.2, fill: false, pointRadius: 3 },
          ...(leagueAvgs ? [
            { label: 'Lg Avg Scored', data: lgAvgScoredArr, borderColor: '#4ade80', borderDash: [5, 4], backgroundColor: 'transparent', tension: 0, fill: false, pointRadius: 0, borderWidth: 1.5 },
            { label: 'Lg Avg Conceded', data: lgAvgConcededArr, borderColor: '#f87171', borderDash: [5, 4], backgroundColor: 'transparent', tension: 0, fill: false, pointRadius: 0, borderWidth: 1.5 },
          ] : []),
        ]
      },
      options: {
        responsive: true,
        plugins: { legend: { labels: { color: '#94a3b8', font: { size: 11 } } } },
        scales: {
          x: { ticks: { color: '#64748b', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' } },
          y: { ticks: { color: '#64748b', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' }, beginAtZero: true }
        }
      }
    });
  }

  // --- Chart 4: Cumulative Goal Difference ---
  let cumGdChartInst;
  function renderCumGdChart(slice) {
    slice = slice || getWindowSlice();
    const labels = sliceLabels(slice);
    let cumGdRunning = 0;
    const cumGdArr = slice.map(g => {
      cumGdRunning += (g.goal_difference != null ? g.goal_difference : (g.goals_scored - g.goals_conceded));
      return cumGdRunning;
    });
    if (cumGdChartInst) cumGdChartInst.destroy();
    cumGdChartInst = new Chart(document.getElementById('cumGdChart'), {
      type: 'line',
      data: {
        labels,
        datasets: [{
          label: 'Cumulative GD',
          data: cumGdArr,
          borderColor: '#6366f1',
          backgroundColor: 'rgba(99,102,241,0.1)',
          tension: 0.2,
          fill: true,
          pointRadius: 3,
        }]
      },
      options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: {
          x: { ticks: { color: '#64748b', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' } },
          y: { ticks: { color: '#64748b', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' } }
        }
      }
    });
  }

  function renderTimeCharts() {
    const slice = getWindowSlice();
    renderGdChart(slice);
    renderAvgPtsChart(slice);
    renderCumGoalsChart(slice);
    renderCumGdChart(slice);
  }
  renderTimeCharts();

  // --- Chart 5: Goals timing ---
  if (timing.length) {
    new Chart(document.getElementById('timingChart'), {
      type: 'bar',
      data: {
        labels: timing.map(b => b.bucket),
        datasets: [
          { label: 'Scored', data: timing.map(b => b.scored), backgroundColor: 'rgba(74,222,128,0.75)', borderColor: '#4ade80', borderWidth: 1, borderRadius: 3 },
          { label: 'Conceded', data: timing.map(b => b.conceded), backgroundColor: 'rgba(248,113,113,0.75)', borderColor: '#f87171', borderWidth: 1, borderRadius: 3 }
        ]
      },
      options: {
        responsive: true,
        plugins: { legend: { labels: { color: '#94a3b8', font: { size: 11 } } } },
        scales: {
          x: { ticks: { color: '#64748b', font: { size: 11 } }, grid: { color: 'rgba(255,255,255,0.04)' } },
          y: { ticks: { color: '#64748b', font: { size: 11 }, stepSize: 1 }, grid: { color: 'rgba(255,255,255,0.04)' }, beginAtZero: true }
        }
      }
    });
  }

  // --- Chart 5: Player Minutes ---
  if (playerMinutes.length) {
    const maxMins = <%- gamesPlayed %> * 90;
    const pmCanvas = document.getElementById('minutesChart');
    pmCanvas.height = Math.max(180, playerMinutes.length * 28);
    const pct = p => maxMins > 0 ? p.minutes / maxMins : 0;
    const barColor = p => {
      const r = pct(p);
      if (r >= 0.9) return 'rgba(74,222,128,0.85)';
      if (r >= 0.7) return 'rgba(163,230,53,0.8)';
      if (r >= 0.5) return 'rgba(250,204,21,0.8)';
      if (r >= 0.3) return 'rgba(251,146,60,0.8)';
      return 'rgba(248,113,113,0.8)';
    };
    new Chart(pmCanvas, {
      type: 'bar',
      data: {
        labels: playerMinutes.map(p => p.player_name),
        datasets: [
          {
            label: 'Minutes Played',
            data: playerMinutes.map(p => p.minutes),
            backgroundColor: playerMinutes.map(barColor),
            borderWidth: 0,
            borderRadius: { topRight: 3, bottomRight: 3 },
            borderSkipped: false,
          },
          {
            label: 'Remaining',
            data: playerMinutes.map(p => Math.max(0, maxMins - p.minutes)),
            backgroundColor: 'rgba(255,255,255,0.05)',
            borderWidth: 0,
            borderRadius: { topRight: 3, bottomRight: 3 },
            borderSkipped: false,
          }
        ]
      },
      options: {
        indexAxis: 'y',
        responsive: true,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              title(items) {
                return playerMinutes[items[0].dataIndex]?.player_name || '';
              },
              label(item) {
                if (item.datasetIndex === 1) return null;
                const p = playerMinutes[item.dataIndex];
                const r = maxMins > 0 ? (p.minutes / maxMins * 100).toFixed(0) : 0;
                return [`${p.minutes} / ${maxMins} mins  (${r}%)`, `${p.apps} apps (${p.starts} starts)`];
              }
            }
          }
        },
        scales: {
          x: { stacked: true, max: maxMins, ticks: { color: '#64748b', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' }, beginAtZero: true },
          y: { stacked: true, ticks: { color: '#94a3b8', font: { size: 11 } }, grid: { color: 'rgba(255,255,255,0.04)' } }
        }
      }
    });
  }

  // --- Charts 6 & 7: Goals by type ---
  if (goalsByType.length) {
    const typeLabels = goalsByType.map(t => t.situation);
    const typeColors = { 'Open Play': '#6366f1', 'Penalty': '#f59e0b', 'Free Kick': '#22d3ee' };
    const bgFor  = goalsByType.map(t => typeColors[t.situation] || '#94a3b8');
    const bgAg   = goalsByType.map(t => (typeColors[t.situation] || '#94a3b8').replace(')', ',0.55)').replace('rgb', 'rgba'));

    function buildTypeChart(canvasId, dataKey, colors) {
      new Chart(document.getElementById(canvasId), {
        type: 'bar',
        data: {
          labels: typeLabels,
          datasets: [{
            data: goalsByType.map(t => t[dataKey]),
            backgroundColor: colors,
            borderWidth: 0,
            borderRadius: 4,
          }]
        },
        options: {
          responsive: true,
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label(item) {
                  const total = goalsByType.reduce((s, t) => s + t[dataKey], 0);
                  const pct = total > 0 ? (item.raw / total * 100).toFixed(0) : 0;
                  return `${item.raw} goals  (${pct}%)`;
                }
              }
            }
          },
          scales: {
            x: { ticks: { color: '#94a3b8', font: { size: 11 } }, grid: { color: 'rgba(255,255,255,0.04)' } },
            y: { ticks: { color: '#64748b', font: { size: 10 }, stepSize: 1 }, grid: { color: 'rgba(255,255,255,0.04)' }, beginAtZero: true }
          }
        }
      });
    }

    buildTypeChart('goalTypeScoredChart',  'scored',   ['rgba(99,102,241,0.85)', 'rgba(245,158,11,0.85)', 'rgba(34,211,238,0.85)']);
    buildTypeChart('goalTypeConcededChart', 'conceded', ['rgba(99,102,241,0.5)',  'rgba(245,158,11,0.5)',  'rgba(34,211,238,0.5)']);
  }

  // --- Strength over Time ---
  if (document.getElementById('strengthChart') && leagueAvgs) {
    // Build round-ordered list of cumulative totals using chronoGames
    let cumGF = 0, cumGA = 0, cumGP = 0;
    const roundLabels = [];
    const attData = [], defData = [], strData = [];

    const lgAvgGF = leagueAvgs.avg_gf;
    const lgAvgGA = leagueAvgs.avg_ga;
    const lgAvgPts = leagueAvgs.avg_pts;

    chronoGames.forEach((g, i) => {
      cumGF += g.goals_scored   || 0;
      cumGA += g.goals_conceded || 0;
      cumGP += 1;

      const gfPerGame = cumGF / cumGP;
      const gaPerGame = cumGA / cumGP;

      const att = lgAvgGF > 0 ? parseFloat((gfPerGame / lgAvgGF).toFixed(2)) : null;
      const def = lgAvgGA > 0 && gaPerGame > 0 ? parseFloat((lgAvgGA / gaPerGame).toFixed(2)) : null;
      const str = att != null && def != null ? parseFloat((0.5 * att + 0.5 * def).toFixed(2)) : null;

      roundLabels.push(`R${g.game_round || i + 1}`);
      attData.push(att);
      defData.push(def);
      strData.push(str);
    });

    // DC season estimates — flat reference lines across all rounds
    const dcAtt = teamStrength && teamStrength.attack_rating  != null ? teamStrength.attack_rating  : null;
    const dcDef = teamStrength && teamStrength.defence_rating != null ? teamStrength.defence_rating : null;
    const dcStr = teamStrength && teamStrength.overall_strength != null ? teamStrength.overall_strength : null;
    const dcFlat = (val) => val != null ? roundLabels.map(() => val) : [];

    const datasets = [
      {
        label: 'Attack (rolling)',
        data: attData,
        borderColor: '#38bdf8',
        backgroundColor: 'rgba(56,189,248,0.06)',
        tension: 0.3, pointRadius: 2, borderWidth: 2, fill: false,
      },
      {
        label: 'Defence (rolling)',
        data: defData,
        borderColor: '#a78bfa',
        backgroundColor: 'rgba(167,139,250,0.06)',
        tension: 0.3, pointRadius: 2, borderWidth: 2, fill: false,
      },
      {
        label: 'Overall (rolling)',
        data: strData,
        borderColor: '#f8fafc',
        backgroundColor: 'rgba(248,250,252,0.04)',
        tension: 0.3, pointRadius: 2, borderWidth: 2.5, fill: false,
      },
    ];

    if (dcAtt != null) datasets.push({
      label: `DC ATT (${dcAtt})`,
      data: dcFlat(dcAtt),
      borderColor: '#7dd3fc',
      borderDash: [6, 3],
      borderWidth: 1.5,
      pointRadius: 0,
      tension: 0,
      fill: false,
    });
    if (dcDef != null) datasets.push({
      label: `DC DEF (${dcDef})`,
      data: dcFlat(dcDef),
      borderColor: '#c4b5fd',
      borderDash: [6, 3],
      borderWidth: 1.5,
      pointRadius: 0,
      tension: 0,
      fill: false,
    });
    if (dcStr != null) datasets.push({
      label: `DC STR (${dcStr})`,
      data: dcFlat(dcStr),
      borderColor: 'rgba(248,250,252,0.5)',
      borderDash: [6, 3],
      borderWidth: 1.5,
      pointRadius: 0,
      tension: 0,
      fill: false,
    });

    new Chart(document.getElementById('strengthChart'), {
      type: 'line',
      data: { labels: roundLabels, datasets },
      options: {
        responsive: true,
        plugins: {
          legend: { labels: { color: '#94a3b8', font: { size: 11 }, boxWidth: 14 } },
          tooltip: {
            callbacks: {
              title: (items) => {
                const g = chronoGames[items[0].dataIndex];
                if (!g) return '';
                const loc = g.game_location === 'home' ? 'vs' : '@';
                return `${roundLabels[items[0].dataIndex]}  ${loc} ${g.opponent_name || ''}`;
              },
              label: (item) => {
                if (item.raw == null) return null;
                const sign = item.raw >= 1 ? '+' : '';
                return `${item.dataset.label}: ${item.raw}  (${sign}${((item.raw - 1) * 100).toFixed(0)}% vs avg)`;
              }
            }
          },
          annotation: {
            annotations: {
              avgLine: { type: 'line', yMin: 1, yMax: 1, borderColor: 'rgba(255,255,255,0.15)', borderWidth: 1, borderDash: [4, 4] }
            }
          }
        },
        scales: {
          x: { ticks: { color: '#64748b', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' } },
          y: {
            min: 0.3,
            max: 2.0,
            ticks: {
              color: '#64748b',
              font: { size: 10 },
              callback: v => v === 1.0 ? 'avg' : v.toFixed(1),
            },
            grid: { color: ctx => ctx.tick.value === 1.0 ? 'rgba(255,255,255,0.18)' : 'rgba(255,255,255,0.04)' }
          }
        }
      }
    });
  }
</script>

<%- include('partials/footer') %>
